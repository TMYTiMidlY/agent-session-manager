# Copilot 历史备份 —— 凭据 + 部署信息（模板）
# 拷成 `secrets.env`、chmod 600、按下面注释填值。提交前 grep '<' 检查没有未填占位。
#
# 仓库里的 backup.sh / README.md 是通用的：所有"实际打到哪台机、哪个 bucket、
# 走什么端口"都从本文件读，换机部署只改本文件即可。
#
# ============================================================================
# 在这里写下你自己的部署链路注释（IP / 端口 / 跳数 / 为什么这么绕），
# 给未来的自己 / 队友看。本机的版本可作为参考：见 secrets.env (gitignored)。
# ============================================================================


# --- restic 仓库地址 ---
# 格式取决于 backend，常见几种：
#   s3:http://<endpoint host>:<port>/<bucket name>     # S3-compatible (含 rustfs/MinIO/R2/B2)
#   s3:https://s3.us-east-1.amazonaws.com/<bucket>     # AWS S3 + HTTPS
#   sftp:<user>@<host>:/path/to/repo                   # SFTP
#   rest:http://<host>:<port>/<path>                   # restic rest-server
#   /srv/restic-repo                                   # 本地路径
# 完整列表: https://restic.readthedocs.io/en/stable/030_preparing_a_new_repo.html
export RESTIC_REPOSITORY="s3:http://<endpoint host>:<port>/<bucket name>"

# --- S3 access key ---（只有 S3 backend 需要；其他 backend 留空或删掉这两行）
# 对该 bucket 至少要有 read / write / delete 权限
export AWS_ACCESS_KEY_ID="<access key id>"
export AWS_SECRET_ACCESS_KEY="<secret access key>"

# --- restic 仓库加密密码 ---
# 整套方案的唯一密钥：丢了就永久解不开所有备份。
# 生成强随机:  openssl rand -base64 32
#         或:  pwgen -s 32 1
# **首次 restic init 后必须立刻把这值复制到密码管理器 / 异机备份**——详见
# README 末尾"重要"段。
export RESTIC_PASSWORD="<32+ 字符强随机密码>"


# --- 可选: 行为开关 ---
# restic 二进制位置（默认 $HOME/.local/bin/restic）
# export RESTIC_BIN="/usr/bin/restic"

# 要备份的 agent 状态目录，冒号分隔。默认:
#   $HOME/.copilot:$HOME/.claude:$HOME/.codex
# export BACKUP_AGENT_DIRS="$HOME/.copilot:$HOME/.claude:$HOME/.codex"

# 设为 1 排除 rewind-snapshots/（省 ~2.0 GiB，但 /rewind 撤销编辑功能不可用；
# 不影响 share-html / --resume / dredge-up，详见 README"备份范围"段）
# export BACKUP_EXCLUDE_REWIND=1
